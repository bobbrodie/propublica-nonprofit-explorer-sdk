{
  "name": "propublica-nonprofit-explorer-sdk",
  "version": "4.0.0",
  "description": "SDK for ProPublica Nonprofit Explorer API",
  "main": "dist/index",
  "types": "dist/index",
  "exports": {
    ".": "./dist/index.js",
    "./constants": "./dist/constants/index.js",
    "./models": "./dist/models/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bobbrodie/propublica-nonprofit-explorer-sdk.git"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p ./tsconfig.json",
    "coverage": "npm run unit -- --coverage",
    "format": "prettier --write .",
    "format:ci": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepare": "husky",
    "test": "npm run format && npm run lint && npm run coverage",
    "unit": "vitest run"
  },
  "keywords": [
    "nonprofit"
  ],
  "author": "Robert Brodie <rbrodie85@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20 <27"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/eslint-config-prettier": "6.11.3",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "lint-staged": {
    "**/*": [
      "eslint --fix",
      "prettier --write ."
    ]
  }
}
